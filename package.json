{
	"name": "snakemake-wasm-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"sync:pyodide": "mkdir -p static/pyodide && rsync -a --delete node_modules/pyodide/ static/pyodide/",
		"sync:assets": "npm run sync:pyodide && mkdir -p static/wheels static/v86 static/thirdparty/v86 && rsync -a --delete ../wheels/ static/wheels/ && rsync -a --delete ../v86/ static/v86/ && rsync -a --delete ../thirdparty/v86/ static/thirdparty/v86/ && cp -f ../Snakefile static/Snakefile",
		"build:app": "npm run check && npm run build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"dependencies": {
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/lang-yaml": "^6.1.2",
		"codemirror": "^6.0.2",
		"pyodide": "^0.29.3"
	},
	"devDependencies": {
		"@skeletonlabs/skeleton": "^4.12.1",
		"@skeletonlabs/skeleton-svelte": "^4.12.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
